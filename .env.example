# Environment variables for XMR Fund Transparency Suite
# Copy this file to .env and fill in your values

# === Instance / Multi-Instance ===
# Unique project name for Docker Compose isolation.
# Each instance on the same host MUST have a unique COMPOSE_PROJECT_NAME
# to prevent container name and network collisions.
# Setup.sh sets this automatically based on --instance=NAME.
# Examples: xmrfts-prod, xmrfts-demo, xmrfts-staging
COMPOSE_PROJECT_NAME=xmrfts-prod

# === Host Ports ===
# Host-side ports for each service. Container-internal ports are NOT changed.
# When running multiple instances on the same host, each instance MUST use
# a unique set of host ports to avoid "bind: address already in use" errors.
# Setup.sh assigns preset ports based on --instance=NAME:
#   prod (default):  3000 / 8000 / 5432 / 6379 / 18082
#   demo:           3001 / 8001 / 5433 / 6380 / 18083
#   staging:        3002 / 8002 / 5434 / 6381 / 18084
FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
MONERO_RPC_PORT=18082

# === Environment ===
# Values: local, dev, staging, production
ENVIRONMENT=local

# === APP URL ===
APP_URL=dashboard.xmrfts.com

# === Required ===
DB_PASSWORD=changeme_use_strong_password
API_KEY=changeme_use_random_64_char_hex
VIEW_KEY_MASTER_SECRET=changeme_encrypts_view_keys_in_db

# === Monero Wallet RPC ===
MONERO_RPC_URL=http://monero-wallet-rpc:18082/json_rpc
MONERO_DAEMON_ADDRESS=node.moneroworld.com:18089
MONERO_WALLET_FILE=/data/wallet

# === Database ===
DATABASE_URL=postgresql+asyncpg://xmruser:changeme_use_strong_password@postgres/xmrdashboard

# === Redis ===
REDIS_URL=redis://redis:6379

# === Scanner ===
SCAN_INTERVAL=60

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json

# === Security ===
CORS_ORIGINS=http://localhost:3000
COOKIE_SECURE=true
COOKIE_SAMESITE=Strict

# === Optional ===
# SENTRY_DSN=
# VIEW_KEY_ENCRYPTION=true
